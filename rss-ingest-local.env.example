# Copy this file to rss-ingest-local.env and fill local secrets there.
# rss-ingest-local.env is intentionally ignored by Git.

# Feishu base config
FEISHU_APP_ID =
FEISHU_APP_SECRET =
FEISHU_APP_TOKEN =
FEISHU_NEWS_TABLE_ID =
FEISHU_RSS_TABLE_ID =
FEISHU_FILTERED_TABLE_ID =
FEISHU_KEYWORD_TABLE_ID =
FEISHU_NOTIFY_TABLE_ID =
FEISHU_WEBHOOK_URL =

# Optional secondary sync
ENABLE_SECONDARY_SYNC = false
FEISHU_SYNC_TABLE_ID =
FEISHU_SYNC_APP_TOKEN =

# Online config document (Feishu docx token)
FEISHU_CONFIG_DOC_TOKEN = TVrPdbUpjoCWrPxEl9bccvRKnLd

# Local prompt files (fallback when Feishu config doc unavailable)
LOCAL_KEYWORD_BLOCKLIST_PATH = docs/local-keyword-blocklist.txt
LOCAL_SCREEN_PROMPT_PATH = docs/local-screen-prompt.md
LOCAL_SUMMARIZE_PROMPT_PATH = docs/local-summarize-prompt.md
LOCAL_PROMPT_RULES_PATH = docs/local-prompt-rules.md
LOCAL_SCREEN_KEYWORDS_ADDENDUM_PATH =

# Network
USE_SYSTEM_PROXY = true
ENABLE_IMAGE_ATTACHMENTS = true
IMAGE_ATTACHMENT_MAX_PER_RECORD = 10
IMAGE_ATTACHMENT_MAX_BYTES = 5242880
IMAGE_ATTACHMENT_TIMEOUT = 12
# Exact public image CDN hosts allowed to use Clash-style 198.18.0.0/15 fake-IP DNS answers.
IMAGE_ATTACHMENT_PROXY_FAKE_IP_HOSTS = pbs.twimg.com,video.twimg.com,article-images.zsxq.com,breakout-1301344553.cos.ap-beijing.myqcloud.com,i.redd.it,preview.redd.it,external-preview.redd.it,mmbiz.qpic.cn
ARTICLE_FETCH_MAX_BYTES = 2097152
FEISHU_HTTP_RETRIES = 7
FEISHU_RETRY_BASE_SECONDS = 1.5
FEISHU_RETRY_MAX_SECONDS = 30

# Fetch and dedup
DEFAULT_FETCH_INTERVAL_MIN = 180
# all = local/default behavior; github = public HTTP(S) plus explicitly mapped private feed files.
RSS_SOURCE_MODE = all
# GitHub mode JSON mapping. Paths inside the file are resolved relative to the mapping file.
RSS_SOURCE_OVERRIDE_FILE =
RSS_FETCH_CONCURRENCY = 20
RSS_FETCH_PER_HOST_CONCURRENCY = 4
RSS_FETCH_RETRY_CONCURRENCY = 4
RSS_SOURCE_FAILURE_EXIT_COUNT = 10
RSS_SOURCE_FAILURE_EXIT_RATIO = 0.25
RSS_INGEST_ITEM_KEY_PREFETCH_ATTEMPTS = 2
NEWS_ITEM_KEY_PREFETCH_MAX_PAGES = 50
ITEM_KEY_PREFETCH_DEFAULT_DAYS = 30
TEXT_DEDUP_PREFETCH_MAX_PAGES = 2
TEXT_DEDUP_PROVIDER = ark

# Browser article fallback
# Uses the logged-in gpt-browser Chrome profile for Medium/Towards AI previews.
ENABLE_BROWSER_ARTICLE_FETCH = false
# X/Twitter browser fallback opens/uses the gpt-browser Chrome profile; keep false for desktop-zero-feel.
ENABLE_X_BROWSER_FALLBACK = false
BROWSER_ARTICLE_FETCH_COMMAND = node
BROWSER_ARTICLE_FETCH_NODE_MODULES =
BROWSER_ARTICLE_FETCH_ENDPOINT_FILE =

# Grok watch local X-search feeds
# web = use logged-in grok.com in the gpt-browser Chrome profile; cli/api are explicit fallbacks.
GROK_WATCH_TRANSPORT = web
GROK_WATCH_WEB_MODEL = Expert
GROK_WATCH_WEB_URL = https://grok.com/?q=&reasoningMode=none&voice=false
GROK_WATCH_WEB_COMMAND = node
GROK_WATCH_GROK_BROWSER_CLI =
GROK_WATCH_WEB_NODE_MODULES =
GROK_WATCH_WEB_ENDPOINT_FILE =
GROK_WATCH_GPT_BROWSER_COMMAND = gpt-browser
GROK_WATCH_GPT_BROWSER_LAUNCH_TIMEOUT_S = 90

# KEYWORD index snapshot/cache
ENABLE_KEYWORD_SNAPSHOT_INDEX = true
KEYWORD_SNAPSHOT_GIT_REF = origin/main
KEYWORD_SNAPSHOT_GIT_PATH = data/keyword_snapshot.json
KEYWORD_SNAPSHOT_GIT_FETCH = true
KEYWORD_SNAPSHOT_GIT_TIMEOUT = 15
KEYWORD_SNAPSHOT_GIT_FETCH_INTERVAL_MIN = 60
KEYWORD_SNAPSHOT_URL =
KEYWORD_SNAPSHOT_PATH = data/keyword_snapshot.json
KEYWORD_RUNTIME_SNAPSHOT_PATH = .cache/keyword_snapshot_runtime.json
KEYWORD_SNAPSHOT_TIMEOUT = 8
KEYWORD_SNAPSHOT_MIN_ENTRIES = 1000
KEYWORD_SNAPSHOT_MAX_AGE_HOURS = 6

# LLM provider
LLM_PROVIDER = ark
SCREEN_PROVIDER =
FEISHU_MIN_SCORE = 6.0
LLM_CONCURRENCY = 4

# Volcengine Ark Coding Plan. d = deepseek-v4-flash; dsp = deepseek-v4-pro.
# ARK_BASE_URL must be the Coding endpoint, not the regular Ark /api/v3 endpoint.
ARK_API_KEY =
ARK_API_KEY_2 =
ARK_BASE_URL = https://ark.cn-beijing.volces.com/api/coding/v3
ARK_MODEL = deepseek-v4-flash
ARK_TIMEOUT = 60
ARK_RETRIES = 10
ARK_PARSE_RETRIES = 3
ARK_DISABLE_THINKING = true

# Gemini fallback / provider
# developer = AI Studio / Gemini Developer API, uses GEMINI_API_KEY.
# vertex = Google Cloud Vertex AI, uses ADC/WIF + GOOGLE_CLOUD_PROJECT.
GEMINI_BACKEND = developer
GEMINI_API_KEY =
GEMINI_MODEL_NAME = gemini-3-flash-preview
GOOGLE_CLOUD_PROJECT =
GOOGLE_CLOUD_LOCATION = global
GOOGLE_VERTEX_MODEL = gemini-3-flash-preview

# Other OpenAI-compatible providers
IFLOW_API_KEY =
IFLOW_BASE_URL = https://apis.iflow.cn/v1
IFLOW_MODEL = qwen3-max
IFLOW_TIMEOUT = 60
IFLOW_RETRIES = 10
OPENAI_API_KEY =
OPENAI_BASE_URL = https://api.openai.com/v1
OPENAI_MODEL = gpt-5
OPENAI_TIMEOUT = 60
OPENAI_RETRIES = 10
DEEPSEEK_API_KEY =
DEEPSEEK_BASE_URL = https://api.deepseek.com
DEEPSEEK_MODEL = deepseek-v4-flash
DEEPSEEK_SCREEN_MODEL =
DEEPSEEK_TIMEOUT = 60
DEEPSEEK_RETRIES = 10
ZHIPU_API_KEY =
ZHIPU_BASE_URL = https://open.bigmodel.cn/api/paas/v4
ZHIPU_MODEL = glm-4.7
ZHIPU_TIMEOUT = 60
ZHIPU_RETRIES = 10

# Notify table field names
NOTIFY_FIELD_EVENT = 事件
NOTIFY_FIELD_DETAIL = 详情
NOTIFY_FIELD_PLAIN = 说明
NOTIFY_FIELD_TRIGGER_TIME = 触发时间
NOTIFY_FIELD_NOTIFIED = 已通知

# Prompt limits
PROGRESS_BAR_WIDTH = 20
PROMPT_TITLE_MAX_CHARS = 300
PROMPT_CONTENT_MAX_CHARS = 12000
